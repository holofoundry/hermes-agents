# Optional. Defaults to https://esi.evetech.net/latest.
EVE_ESI_BASE_URL=https://esi.evetech.net/latest

# Optional. Public ESI market data normally uses tranquility.
EVE_ESI_DATASOURCE=tranquility

# Optional. If unset, the server sends today's UTC date minus 11 hours.
# ESI compatibility dates must not be in the future.
# EVE_ESI_COMPATIBILITY_DATE=YYYY-MM-DD

# Optional request timeout in seconds.
EVE_ESI_TIMEOUT=30
